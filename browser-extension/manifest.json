{
  "manifest_version": 3,
  "name": "Dory Memory",
  "version": "0.9.3",
  "description": "Persistent memory panel for browser-based AI chats. Connects to your local Dory instance.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "http://127.0.0.1:7341/*",
    "https://claude.ai/*",
    "https://chatgpt.com/*",
    "https://gemini.google.com/*",
    "https://perplexity.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content/base.js", "content/claude.js"],
      "css": ["sidebar/sidebar.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content/base.js", "content/chatgpt.js"],
      "css": ["sidebar/sidebar.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content/base.js", "content/gemini.js"],
      "css": ["sidebar/sidebar.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://perplexity.ai/*"],
      "js": ["content/base.js", "content/perplexity.js"],
      "css": ["sidebar/sidebar.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-dory": {
      "suggested_key": {
        "default": "Ctrl+Shift+M",
        "mac": "Command+Shift+M"
      },
      "description": "Toggle Dory memory panel"
    }
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": false
  },
  "action": {
    "default_title": "Dory Memory",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
